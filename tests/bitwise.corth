// shift left
1  3 shl 8 != if
    "Test 1 didn't pass." 1 1 syscall3
end
// shift right
32 3 shr 4 != if
    "Test 2 didn't pass." 1 1 syscall3
end
// or byte
1  2 orb 3 != if
    "Test 3 didn't pass." 1 1 syscall3
end
// and byte
1  2 andb 0 != if
    "Test 4 didn't pass." 1 1 syscall3
end